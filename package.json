{
  "name": "@foundry/agent-primitives",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "bun run --bun tsc --noEmit",
    "test": "bun test tests/*.test.ts",
    "pretest:db": "DATABASE_URL=postgresql://postgres:postgres@localhost:5532/foundry_test bunx prisma db push --skip-generate",
    "test:db": "DATABASE_URL=postgresql://postgres:postgres@localhost:5532/foundry_test bun test tests/db/ --max-concurrency=1",
    "test:all": "bun test tests/*.test.ts && bun run test:db",
    "db:push": "bunx prisma db push",
    "db:push:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5532/foundry_test bunx prisma db push",
    "setup": "bun run src/setup.ts",
    "start": "bun run src/start.ts",
    "viewer": "bun run src/viewer/server.ts",
    "demo": "bun run src/demo.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "consola": "^3.4.2",
    "hono": "^4.7.0",
    "prisma": "^6.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "pino": "^10.3.1",
    "typescript": "^5.7.0"
  }
}

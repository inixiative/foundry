{
  "name": "@inixiative/foundry-monorepo",
  "private": true,
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "bun test ./packages/core/tests/ && bun test ./packages/foundry/tests/*.test.ts",
    "test:core": "bun test ./packages/core/tests/",
    "test:foundry": "bun test ./packages/foundry/tests/*.test.ts",
    "test:db": "DATABASE_URL=postgresql://postgres:postgres@localhost:5532/foundry_test bun test ./packages/foundry/tests/db/ --max-concurrency=1",
    "test:all": "bun run test && bun run test:db",
    "setup": "bun run packages/foundry/src/setup.ts",
    "start": "bun run packages/foundry/src/start.ts",
    "viewer": "bun run packages/foundry/src/viewer/server.ts",
    "demo": "bun run packages/foundry/src/demo.ts",
    "research": "bun run packages/foundry/src/research/cli.ts",
    "db:push": "bunx prisma db push",
    "db:push:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5532/foundry_test bunx prisma db push"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}

# ========================================
# Foundry — Test Environment
# ========================================
# Copy to .env.test and modify as needed.
# Requires: docker compose up -d
# ========================================

ENVIRONMENT=test
NODE_ENV=test

# Test database (separate from dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5532/foundry_test

# Redis (shared with dev for now)
REDIS_URL=redis://localhost:6379

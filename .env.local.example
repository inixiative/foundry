# ========================================
# Foundry — Local Environment
# ========================================
# Copy to .env.local and modify as needed.
# ========================================

NODE_ENV=development
ENVIRONMENT=local

# Project Identity
PROJECT_NAME=foundry

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foundry

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Viewer
VIEWER_PORT=4400

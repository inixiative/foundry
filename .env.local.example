# ========================================
# Foundry — Local Environment
# ========================================
# Copy to .env.local and modify as needed.
# Run `bun run setup` for interactive configuration.
# ========================================

NODE_ENV=development
ENVIRONMENT=local

# Project Identity
PROJECT_NAME=foundry

# LLM Provider (pick one — setup wizard will configure this)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Infrastructure (optional — enables persistence and background jobs)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5532/foundry
# REDIS_URL=redis://localhost:6380
#
# With both DATABASE_URL + REDIS_URL: traces/messages/signals persist via BullMQ background jobs
# With DATABASE_URL only: direct synchronous DB writes (no job queue)
# Without either: in-memory only (data lost on restart)

# MuninnDB — neural memory with cognitive features (optional)
# MUNINN_URL=http://localhost:8475

# Viewer
VIEWER_PORT=4400
